{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": ["http://127.0.0.1:4173/index.html"],
      "startServerCommand": "node serve-local.js",
      "startServerReadyPattern": "Serving",
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["accessibility"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }]
      }
    }
  }
}
